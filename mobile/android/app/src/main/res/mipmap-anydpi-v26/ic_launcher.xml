<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (API 26+).
  - background: solid white (#FFFFFF) defined in values/ic_launcher_background.xml
  - foreground: VectorDrawable wi-fi monogram in drawable/ic_launcher_foreground.xml
  - monochrome: reuses the foreground VectorDrawable (tinted by the system, API 33+)
  Legacy PNG mipmaps (mipmap-{m,h,xh,xxh,xxxh}dpi/ic_launcher.png) remain as the
  pre-API-26 fallback and are untouched.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
