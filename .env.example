# Docker Compose environment file (repo root).
#
# Copy to an out-of-repo location with 0600 perms, e.g. /etc/wasel/compose.env,
# and load it via:   docker compose --env-file /etc/wasel/compose.env up -d
#
# DO NOT commit a populated .env — root .gitignore excludes it, but never paste
# real values here. Generate each secret with: openssl rand -hex 32

POSTGRES_PASSWORD=REPLACE_WITH_openssl_rand_hex_32
REDIS_PASSWORD=REPLACE_WITH_openssl_rand_hex_32
