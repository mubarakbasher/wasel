######################################################################
#
#   Wasel — Default virtual server
#
#   Handles RADIUS Authentication (port 1812) and Accounting (port 1813).
#   All user data is stored in PostgreSQL via the sql module.
#
######################################################################

server default {

    listen {
        type = auth
        ipaddr = *
        port = 1812
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
    }

    #
    #  Authorization — look up the user in the database
    #
    authorize {
        #
        #  Read the 'filter' attribute from the request (handles
        #  User-Name normalization, etc.)
        #
        filter_username

        #
        #  If the user supplied a plain-text password via PAP, set
        #  Auth-Type := PAP so the pap module handles verification later.
        #
        preprocess

        #
        #  If the request contains CHAP-Password, set Auth-Type := CHAP
        #
        chap

        #
        #  If the request contains MS-CHAP attributes, set Auth-Type := MS-CHAP
        #
        mschap

        #
        #  Pull user attributes from radcheck, radreply, radusergroup,
        #  radgroupcheck, radgroupreply.
        #  This is where Cleartext-Password, Expiration, Simultaneous-Use,
        #  Mikrotik-Rate-Limit, Session-Timeout, etc. are loaded.
        #
        sql

        #
        #  Check the Expiration attribute loaded from radcheck.
        #  Rejects the request if the current time is past the expiration date.
        #
        expiration

        #
        #  Enforce cumulative time limit via sqlcounter.
        #  Compares radacct totals against the Max-All-Session check attribute.
        #  (Data limits are enforced router-side via Mikrotik-Total-Limit
        #  reply attributes plus the backend usageLimitEnforcement /
        #  dataUsageCoaDisconnect jobs — see mods-enabled/sqlcounter.)
        #
        max_all_session

        #
        #  If Auth-Type has not been set yet and we have a known good
        #  password from the database, the pap module will set it.
        #
        pap
    }

    #
    #  Authentication — verify the supplied credentials
    #
    authenticate {
        #
        #  PAP — compares User-Password with Cleartext-Password (or NT-Password, etc.)
        #
        Auth-Type PAP {
            pap
        }

        #
        #  CHAP — verifies CHAP-Password
        #
        Auth-Type CHAP {
            chap
        }

        #
        #  MS-CHAP v1 and v2
        #
        Auth-Type MS-CHAP {
            mschap
        }
    }

    #
    #  Pre-accounting — set Acct-Type if needed
    #
    preacct {
        preprocess
        acct_unique
    }

    #
    #  Accounting — write Start/Interim/Stop records to radacct
    #
    accounting {
        sql
    }

    #
    #  Session — used for Simultaneous-Use checking
    #  When radcheck contains Simultaneous-Use := 1, FreeRADIUS queries
    #  radacct to count active sessions for the user.
    #
    session {
        sql
    }

    #
    #  Post-Auth — runs after successful or failed authentication
    #  Logs auth attempts to radpostauth table.
    #
    post-auth {
        sql

        #
        #  On Access-Reject, still log to radpostauth for auditing
        #
        Post-Auth-Type REJECT {
            #  Wasel: surface the real reject reason as Reply-Message so the MikroTik
            #  captive-portal login page can show it (expired / disabled / over-limit)
            #  instead of the generic "invalid username or password". Derived at reject
            #  time from voucher_meta + the radcheck Expiration row. This runs ONLY on
            #  rejects; on an empty/error result it sets nothing and the page falls back
            #  to RouterOS's default string, so it can never affect a successful login.
            #
            #  Belt-and-suspenders: the %{sql:} xlat already auto-escapes the
            #  User-Name expansion in FR 3.2, but since User-Name is attacker-
            #  controllable on the reject path we additionally gate the whole
            #  lookup on a strict voucher-username character class. A malformed
            #  username simply gets no custom Reply-Message (RouterOS default),
            #  which is the right UX for a wrong-code attempt anyway. The
            #  radpostauth-logging `sql` call stays OUTSIDE this guard so every
            #  reject is still audited.
            if (&User-Name =~ /^[A-Za-z0-9._-]+$/) {
                update control {
                    &Tmp-String-0 := "%{sql: \
                        SELECT CASE \
                          WHEN vm.status = 'disabled' THEN 'voucher disabled' \
                          WHEN EXISTS (SELECT 1 FROM radcheck rc WHERE rc.username = vm.radius_username \
                               AND rc.attribute = 'Expiration' \
                               AND to_timestamp(rc.value, 'Month DD YYYY HH24:MI:SS') AT TIME ZONE 'UTC' < NOW()) \
                            THEN 'voucher expired' \
                          WHEN vm.status = 'expired' AND vm.limit_type = 'data' THEN 'data limit reached' \
                          WHEN vm.status = 'expired' AND vm.limit_type = 'time' THEN 'time limit reached' \
                          WHEN vm.status = 'expired' THEN 'voucher expired' \
                          ELSE '' END \
                        FROM voucher_meta vm WHERE vm.radius_username = '%{User-Name}' LIMIT 1}"
                }
                if (&control:Tmp-String-0 != '') {
                    update reply {
                        &Reply-Message := "%{control:Tmp-String-0}"
                    }
                }
            }
            sql
        }
    }
}
