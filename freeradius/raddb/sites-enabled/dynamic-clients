######################################################################
#
#   Wasel — Dynamic clients virtual server (FreeRADIUS 3.2.4)
#
#   Invoked by the `lookup_wasel_nas` client stanza in clients.conf
#   whenever FreeRADIUS receives an Access-Request from a 10.10.0.x IP
#   that is not already loaded as a /32 client. We query the `nas` table
#   in PostgreSQL for the matching row and populate the control
#   attributes FreeRADIUS needs to build a client entry on the fly.
#
#   The cached client stays in memory for `lifetime` seconds (declared
#   in clients.conf); after expiry, the next packet from that IP comes
#   back through this server and re-reads the row. That means a
#   rotated shared secret propagates within one lifetime window without
#   needing a full FR restart.
#
#   Why this exists: FreeRADIUS 3.2.4's `read_clients = yes` only runs
#   at startup, and `radmin -e hup` does NOT re-read SQL clients. The
#   previous approach — having the backend insert a nas row then
#   `docker restart wasel-freeradius` over a bind-mounted docker.sock —
#   turned into a three-commit debugging cycle (see 588eeb5, db9a09f,
#   f7f7e97) without ever reliably unblocking production. Dynamic
#   clients move the lookup to FR itself so the backend's only
#   onboarding responsibility becomes inserting the nas row.
#
######################################################################

server dynamic_client_server {
    authorize {
        #
        #  Stash the packet source IP and the SQL-looked-up shortname
        #  in control. If the SQL lookup returns empty the NAS isn't
        #  registered — reject cleanly rather than letting FR try to
        #  build a client with empty attributes.
        #
        update control {
            &FreeRADIUS-Client-IP-Address := "%{Packet-Src-IP-Address}"
            &Tmp-String-0                 := "%{sql:SELECT shortname FROM nas WHERE nasname = '%{Packet-Src-IP-Address}'}"
        }

        if (&control:Tmp-String-0 == "") {
            update reply {
                Reply-Message := "Unknown NAS %{Packet-Src-IP-Address}"
            }
            reject
        }

        #
        #  Populate the remaining client attributes. SQL-quote injection
        #  through %{Packet-Src-IP-Address} is closed off by FR's IPv4
        #  parser: only well-formed 10.10.0.x addresses reach this xlat
        #  (the parent `client lookup_wasel_nas` block constrains
        #  ipaddr = 10.10.0.0/16, and FR rejects malformed source IPs
        #  before dispatching to this virtual server).
        #
        #  FreeRADIUS-Client-Require-MA := no mirrors the global
        #  security{} setting from radiusd.conf so Mikrotik RouterOS,
        #  which can't validate an Access-Accept carrying a
        #  Message-Authenticator over a WireGuard tunnel, keeps working
        #  with dynamically-loaded clients. If this attribute isn't
        #  registered in a specific 3.2.4 build the server will fail to
        #  parse — drop just that line; the global setting is sufficient.
        #
        update control {
            &FreeRADIUS-Client-Shortname  := "%{control:Tmp-String-0}"
            &FreeRADIUS-Client-Secret     := "%{sql:SELECT secret FROM nas WHERE nasname = '%{Packet-Src-IP-Address}'}"
            &FreeRADIUS-Client-NAS-Type   := "other"
            &FreeRADIUS-Client-Require-MA := "no"
        }

        ok
    }
}
