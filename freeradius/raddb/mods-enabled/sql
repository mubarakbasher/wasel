sql {
    driver = "rlm_sql_postgresql"
    dialect = "postgresql"

    server = "${RADIUS_DB_HOST}"
    port = ${RADIUS_DB_PORT}
    login = "${RADIUS_DB_USER}"
    password = "${RADIUS_DB_PASS}"
    radius_db = "${RADIUS_DB_NAME}"

    # Table names
    acct_table1 = "radacct"
    acct_table2 = "radacct"
    postauth_table = "radpostauth"
    authcheck_table = "radcheck"
    groupcheck_table = "radgroupcheck"
    authreply_table = "radreply"
    groupreply_table = "radgroupreply"
    usergroup_table = "radusergroup"

    # Group attribute
    group_attribute = "SQL-Group"

    # NAS clients are loaded ENTIRELY via the dynamic_client_server vserver
    # (see clients.conf and sites-enabled/dynamic-clients), NOT via the
    # boot-time bulk SELECT. read_clients = yes used to coexist with
    # dynamic_clients but caused a footgun: rows loaded at boot become
    # *static* in-memory clients with no TTL, so a delete-then-recreate-
    # same-tunnel-IP swap (or a secret rotation) leaves FR auth'ing
    # against the stale secret forever — dynamic_clients only fires for
    # UNKNOWN IPs, never for already-loaded ones. With read_clients = no
    # every client is dynamic, every row change is picked up within
    # `lifetime` seconds (clients.conf), and there is one source of truth.
    read_clients = no
    client_table = "nas"

    # Use standard PostgreSQL queries
    $INCLUDE ${modconfdir}/sql/main/${dialect}/queries.conf

    # Time to wait for a new Postgres connection before giving up (seconds).
    connect_timeout = 5

    pool {
        start = 5
        min = 4
        max = 10
        spare = 3
        uses = 0
        lifetime = 0
        idle_timeout = 60
        # Retry a dead connection every 5s instead of the default long back-off,
        # so a Postgres restart recovers in seconds rather than a minute.
        retry_delay = 5
    }
}
