sql {
    driver = "rlm_sql_postgresql"
    dialect = "postgresql"

    server = "${env:RADIUS_DB_HOST:-postgres}"
    port = 5432
    login = "${env:RADIUS_DB_USER:-wasel}"
    password = "${env:RADIUS_DB_PASS:-changeme}"
    radius_db = "${env:RADIUS_DB_NAME:-wasel}"

    # Table names
    acct_table1 = "radacct"
    acct_table2 = "radacct"
    postauth_table = "radpostauth"
    authcheck_table = "radcheck"
    groupcheck_table = "radgroupcheck"
    authreply_table = "radreply"
    groupreply_table = "radgroupreply"
    usergroup_table = "radusergroup"

    # Read NAS clients from the 'nas' table
    read_clients = yes
    client_table = "nas"

    # Use standard PostgreSQL queries
    $INCLUDE ${modconfdir}/sql/main/${dialect}/queries.conf

    pool {
        start = 5
        min = 4
        max = 10
        spare = 3
        uses = 0
        lifetime = 0
        idle_timeout = 60
    }
}
