#
#  Wasel — SQL-based counters for enforcing cumulative time limits.
#
#  This counter queries the radacct table to track cumulative usage
#  and compare against the Max-All-Session check attribute.
#  (Cumulative-data enforcement previously lived here as a second
#  sqlcounter; see the NOTE further down for why it was retired.)
#

#
#  Total session time counter (no reset — lifetime of the voucher)
#  Checks the Max-All-Session attribute in radcheck/radgroupcheck.
#
sqlcounter max_all_session {
    sql_module_instance = sql
    dialect = postgresql

    counter_name = Max-All-Session
    check_name = Max-All-Session
    reply_name = Session-Timeout

    key = User-Name

    reset = never

    query = "\
        SELECT COALESCE(SUM(acctsessiontime), 0) \
        FROM radacct \
        WHERE username = '%{${key}}'"
}

#
#  NOTE: the former cumulative-data sqlcounter has been retired.
#  rlm_sqlcounter binds its check attribute to a 32-bit integer, so it
#  cannot represent byte limits above 4 GB (it would reject large data
#  vouchers early on the low 32 bits of the split limit) — see the
#  FreeRADIUS wiki page for rlm_sqlcounter (documents check_name /
#  reply_name semantics):
#      https://wiki.freeradius.org/modules/Rlm_sqlcounter
#  Data-limit enforcement now lives on the router via the
#  Mikrotik-Total-Limit (+ Mikrotik-Total-Limit-Gigawords) reply
#  attributes written to radreply — see the MikroTik RADIUS
#  attributes reference:
#      https://help.mikrotik.com/docs/spaces/ROS/pages/328097/RADIUS
#  plus the backend usageLimitEnforcement (auth-time latch) and
#  dataUsageCoaDisconnect (live CoA backstop) jobs — full 64-bit
#  precision.
#
