# Server
NODE_ENV=production
PORT=3000

# PostgreSQL (backend uses network_mode:host, connect via localhost)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=wasel
DB_USER=wasel
DB_PASSWORD=<run: openssl rand -hex 32>
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=<run: openssl rand -hex 32>
JWT_REFRESH_SECRET=<run: openssl rand -hex 32>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=<run: openssl rand -hex 32>

# CORS
CORS_ORIGIN=https://wa-sel.com,https://api.wa-sel.com,https://admin.wa-sel.com

# WireGuard (generate on VPS: wg genkey | tee privatekey | wg pubkey > publickey)
# WG_SERVER_ENDPOINT: hostname OR IPv4 OR bracketed IPv6, with optional :<port>.
#
# STRONGLY prefer a DNS hostname (e.g. wg.wa-sel.com). Every router's peer
# stores this value as `endpoint-address=`, so a raw IP means the fleet can
# never be repointed off a bad IP without editing every router by hand.
# With a DNS hostname a single DNS record change repoints the whole fleet.
WG_SERVER_PRIVATE_KEY=<run: wg genkey>
WG_SERVER_PUBLIC_KEY=<run: echo "PRIVATE_KEY" | wg pubkey>
WG_SERVER_ENDPOINT=wg.wa-sel.com
WG_SERVER_PORT=51820

# SMTP (Resend — https://resend.com)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=<your-resend-api-key>
SMTP_FROM=noreply@wa-sel.com

# FreeRADIUS
RADIUS_HOST=127.0.0.1
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_COA_PORT=3799

# Public base URL — must be reachable from the router over the internet (not the WireGuard tunnel).
# Used to build the hotspot-template file URLs that the router fetches via /tool/fetch.
# Production: https://api.wa-sel.com   Staging: https://api.wa-sel.cloud
PUBLIC_BASE_URL=https://api.wa-sel.com
