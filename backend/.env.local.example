# Local-dev backend env. Copy to backend/.env.local (gitignored).
#
# Loaded automatically by backend/src/config/index.ts BEFORE backend/.env,
# so values here override anything in .env. Production has no .env.local
# and behaves exactly as it always has.
#
# Generate fresh keys before first run — these MUST differ from production:
#   openssl rand -hex 32   (for JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, ENCRYPTION_KEY)
#   wg genkey | tee /tmp/wgpriv | wg pubkey   (for WG_SERVER_PRIVATE_KEY / PUBLIC_KEY)

NODE_ENV=development
PORT=3000

# PostgreSQL — docker-compose.dev.yml maps the container to localhost:5436
# (non-default to avoid colliding with other postgres containers on the host).
DB_HOST=127.0.0.1
DB_PORT=5436
DB_NAME=wasel
DB_USER=wasel
DB_PASSWORD=devpass
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis — docker-compose.dev.yml maps the container to localhost:6380
# (non-default to avoid colliding with other redis containers on the host).
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=devpass

# JWT — generate fresh, do NOT reuse production secrets.
JWT_ACCESS_SECRET=__GENERATE_WITH_OPENSSL_RAND_HEX_32__
JWT_REFRESH_SECRET=__GENERATE_WITH_OPENSSL_RAND_HEX_32__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption — 64 hex chars (32 bytes), generate fresh.
ENCRYPTION_KEY=__GENERATE_WITH_OPENSSL_RAND_HEX_32__

# CORS — admin Vite dev server + Android emulator default.
# Add http://<your-LAN-IP>:5173 etc. if running admin from another device.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://10.0.2.2:3000

# WireGuard — only used when bringing up the wireguard container with
# `docker compose -f docker-compose.dev.yml --profile router-test up -d wireguard`.
# For daily UI/API work the backend tolerates wg0 being absent (warns and
# continues; routers will simply show offline).
WG_SERVER_PRIVATE_KEY=__GENERATE_WITH_WG_GENKEY__
WG_SERVER_PUBLIC_KEY=__GENERATE_WITH_WG_PUBKEY__
WG_SERVER_ENDPOINT=127.0.0.1
WG_SERVER_PORT=51820

# SMTP — captured by MailHog. Open http://localhost:8025 to read mail.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@wasel.local

# FreeRADIUS — runs in docker-compose.dev.yml with network_mode: host,
# so its ports are on the WSL2 host loopback.
RADIUS_HOST=127.0.0.1
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_COA_PORT=3799

# Public base URL — only matters when a real router pairs over WG. For
# local UI/API work, leave as localhost.
PUBLIC_BASE_URL=http://localhost:3000
